# Copiar a `.env` y rellenar. NUNCA commitear `.env`.

# --- Supabase ---
# URL del proyecto: https://<ref>.supabase.co
SUPABASE_URL=
# Service role key (panel Supabase > Settings > API). Da acceso total
# a la BD; jamás compartir ni meter en la app móvil.
SUPABASE_SERVICE_ROLE_KEY=

# Management API (panel Supabase > Account > Access Tokens). Solo
# necesario para aplicar migraciones DDL desde scripts; el CRUD del
# día a día no lo usa. En Railway estos dos son opcionales.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# --- Autenticación cliente ↔ cerebro ---
# Token compartido que la app envía en el header `X-Matix-Key`.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
MATIX_API_KEY=

# --- Entorno ---
# `dev` para local con cleartext localhost permitido en la app.
# `prod` cuando el cerebro corre detrás de HTTPS público.
MATIX_ENV=dev

# --- LLM provider (Capa 2 en adelante) ---
# Decisión: OpenAI como único proveedor. La llamada al modelo vive
# detrás de `cerebro/app/matix/llm.py` para que cambiar de proveedor
# sea editar un archivo y no una reescritura.
OPENAI_API_KEY=

# --- CORS (opcional) ---
# Por defecto el cerebro NO habilita CORS — la app Android es cliente
# nativo, no navegador. Si en el futuro hay una versión web, listar
# orígenes permitidos separados por coma. Vacío = deny-all browser.
MATIX_CORS_ORIGINS=
