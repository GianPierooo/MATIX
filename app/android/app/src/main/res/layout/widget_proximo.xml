<?xml version="1.0" encoding="utf-8"?>
<!-- Widget "Próximo": compacto y glanceable, una sola cosa con jerarquía fuerte
     (hora grande monospace, título claro, relativo "en X min"). El nativo SOLO
     renderiza las claves que empuja la app. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/prox_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/prox_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PRÓXIMO"
            android:textColor="@color/matix_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />
        <TextView
            android:id="@+id/prox_rel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/matix_accent"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Contenido: barra de color + hora grande + título + sub. -->
    <LinearLayout
        android:id="@+id/prox_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/prox_bar"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:background="@color/matix_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/prox_hora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="@color/matix_text"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/prox_titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/matix_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/prox_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/matix_muted"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Estado vacío / día cerrado (nunca un widget en blanco). -->
    <TextView
        android:id="@+id/prox_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:text="Abre Matix para ver tu día"
        android:textColor="@color/matix_muted"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
