<?xml version="1.0" encoding="utf-8"?>
<!-- Widget "Próximo": compacto y redimensionable. `updatePeriodMillis` es el
     refresco NATIVO de respaldo (re-renderiza lo último empujado); el refresco
     con datos frescos lo hace la app (on-change) + WorkManager. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_proximo"
    android:previewLayout="@layout/widget_proximo"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_proximo_desc" />
