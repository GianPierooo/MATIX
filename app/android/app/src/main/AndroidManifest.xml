<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTERNET es OBLIGATORIO en release: Flutter solo lo añade
         automáticamente en builds debug/profile vía el manifest
         fragment. Sin esto, una APK release lanza
         `SocketException: Operation not permitted (errno=1)` en
         cualquier petición HTTP. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Notificaciones locales (Paso 11). -->
    <!-- POST_NOTIFICATIONS: Android 13+ requiere pedir permiso runtime. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- RECEIVE_BOOT_COMPLETED: para reprogramar las notificaciones al
         reiniciar el teléfono (el sistema las pierde con el reboot). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- SCHEDULE_EXACT_ALARM (Android 12) / USE_EXACT_ALARM (Android 13+):
         para que las notificaciones disparen al minuto exacto. En Android
         14+ requiere también un toggle en Ajustes del sistema. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>

    <!-- Voz de entrada para Matix (Capa 2 Paso 3). RECORD_AUDIO requiere
         permiso runtime; lo pedimos con permission_handler antes de
         empezar la grabación. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Wake word en SEGUNDO PLANO (foreground service de micrófono): escuchar
         "hey jarvis" con la app cerrada / pantalla apagada. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <!-- Despertar la pantalla y abrir el modo de voz desde el service estando
         bloqueado (patrón de "llamada entrante" con full-screen intent). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Pedir la excepción de optimización de batería (los OEM como Honor matan
         servicios en background; sin esto el service no sobrevive). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <!-- Auto-actualización: el APK se baja y se instala desde el
         navegador del sistema (url_launcher), no in-app. Por eso
         Matix NO declara REQUEST_INSTALL_PACKAGES — la fuente de
         instalación es el navegador, que pide su propio permiso de
         "instalar apps desconocidas". El instalador in-app de
         ota_update crasheaba de forma nativa en el Huawei sin GPS. -->

    <!-- Capa 7 Paso 1: apunte desde foto. CAMERA habilita
         `ImageSource.camera` de image_picker. Para galería NO
         hace falta declarar `READ_MEDIA_IMAGES` — image_picker
         usa el Photo Picker del sistema (Android 13+) que opera
         sin permisos. -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <application
        android:label="matix"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Compartir-a-Matix (Capa 7): recibir texto plano y URLs
                 desde el menú "compartir" de cualquier app (WhatsApp,
                 navegador, notas…). Lo compartido se captura como
                 apunte clasificado. Solo text/plain — las URLs llegan
                 como texto en EXTRA_TEXT. Imágenes / otros tipos NO
                 (paso aparte). MainActivity maneja el intent y lo pasa
                 a Flutter por un MethodChannel. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
        </activity>
        <!-- Foreground service de micrófono para el wake word en segundo plano.
             Corre el pipeline ONNX en Kotlin (sin engine de Flutter) y abre el
             modo de voz por full-screen intent al detectar la palabra. -->
        <service
            android:name=".WakeWordService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- TTS_SERVICE: Android 11+ requiere declarar la intención
             para poder descubrir motores de Text-To-Speech instalados
             en el sistema. Sin esto, `flutter_tts` no encuentra voces
             y queda en silencio. -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE"/>
        </intent>
    </queries>
</manifest>
