# Config del AGENTE LOCAL de Matix. Copia este archivo a  agente_pc/.env
# (GITIGNORED) y rellena el token. NUNCA commitear agente_pc/.env.
#
#   cp agente_pc/.env.example agente_pc/.env
#
# --- Secreto compartido (OBLIGATORIO) ---
# El MISMO valor que la variable AGENTE_PC_TOKEN del cerebro (en Railway, y en
# cerebro/.env para correr el cerebro local). El agente lo presenta al
# conectar; el cerebro lo valida. Genera uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Sin este token, el agente se niega a arrancar.
AGENTE_PC_TOKEN=

# --- Cerebro (WebSocket sobre TLS) ---
# Debe ser wss:// y el host debe coincidir con AGENTE_PC_HOST_ESPERADO. El
# agente rechaza conectar si no se cumple (verificación anti-impostor).
CEREBRO_WS_URL=wss://matix-production.up.railway.app/api/v1/agente/ws
AGENTE_PC_HOST_ESPERADO=matix-production.up.railway.app

# --- Allowlist de carpetas (límite duro de lo que el agente puede tocar) ---
# Separadas por ';' o saltos de línea. '~' se expande al home del usuario. El
# agente SOLO ve lo que cae dentro. La denylist (.ssh, .env, credenciales,
# carpetas de sistema, perfiles de navegador…) GANA por encima de esto: aunque
# algo caiga dentro, es invisible. Edita esta lista a tu gusto.
AGENTE_PC_ALLOWLIST=~/Documents;~/Desktop;~/Downloads

# --- Escotilla (NO tocar salvo que sepas lo que haces) ---
# El agente se niega a correr como administrador/root. Ponlo a 1 solo a
# conciencia (no recomendado).
AGENTE_PC_PERMITIR_ELEVADO=0
