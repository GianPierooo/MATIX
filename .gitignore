# ----- Secretos -----
# Cubre .env, .env.test, .env.production, .env.local, etc. — sin
# bloquear los `.example` que sí van al repo.
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
# Firma del APK: si en el futuro firmamos con un keystore propio,
# ningún .jks ni properties con la contraseña va al repo.
*.jks
app/android/key.properties
# Notas locales con credenciales del keystore (passwords, alias) que
# generamos para subir como secrets a GitHub. Nunca va al repo.
.keystore-creds.local

# Firebase: el `google-services.json` trae el appId del proyecto.
# No es un secreto crítico (Firebase lo considera "client config"),
# pero igual lo mantenemos fuera del repo para que cada checkout
# decida si activar Firebase o no, y para evitar confundir distintos
# proyectos Firebase. En CI lo bajamos desde un secret base64.
app/android/app/google-services.json
app/ios/Runner/GoogleService-Info.plist

# ----- Python / uv / FastAPI -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.uv-cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/

# ----- Flutter / Dart / Android / iOS -----
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/.pub-cache/
app/.pub/
app/build/
app/.idea/
app/*.iml
app/.gradle/
app/android/.gradle/
app/android/local.properties
app/android/key.properties
app/android/app/debug/
app/android/app/profile/
app/android/app/release/
app/android/.kotlin/
app/android/captures/
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
app/macos/Pods/
app/linux/flutter/ephemeral/
app/windows/flutter/ephemeral/
app/coverage/

# ----- Supabase CLI (si se usa después) -----
supabase/.branches/
supabase/.temp/
supabase/.env

# ----- Editores / OS -----
.idea/
.vscode/
!.vscode/settings.json.example
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ----- Screenshots de depuración (adb exec-out screencap) y crash dumps -----
matix_*.png
hs_err_pid*.log
app/android/hs_err_pid*.log

# Grabaciones de voz personales (no versionar)
mi_voz/
/oye_matix.onnx
/logo_matix.png

# Backups de data (export antes de limpiezas destructivas) — no se versiona
backups/
