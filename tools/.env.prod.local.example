# Config de PROD para builds locales (tools/instalar-prod.ps1).
#
# Copia este archivo a  tools/.env.prod.local  y pon la API key real.
# tools/.env.prod.local está en .gitignore (coincide con .env.*), así que
# NUNCA se sube al repo. La clave la pones tú.
#
#   cp tools/.env.prod.local.example tools/.env.prod.local
#   # edita tools/.env.prod.local y pega la key
#
# MATIX_API_KEY es la MISMA que está en cerebro/.env (la que el cerebro valida
# en el header X-Matix-Key). NO la pegues acá en el .example ni en ningún
# archivo versionado.
MATIX_API_KEY=

# URL del cerebro en prod (Railway). No es secreta; este es el valor por
# defecto si no la pones. Cámbiala solo si el despliegue cambia de URL.
MATIX_API_URL=https://matix-production.up.railway.app
